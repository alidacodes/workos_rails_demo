<div class="bg-slate-300 p-10 pb-6 rounded-2xl shadow-lg flex flex-col items-center w-full max-w-md">
  <h2 class="font-medium text-2xl mb-6">Log in to your account</h2>
  <%= link_to login_path, class: "bg-sky-900 text-slate-50 px-8 py-5 rounded-xl inline-flex items-center-safe font-semibold text-lg" do %>
    <span class="inline-flex items-center-safe">Log in with SSO <%= icon "enter", class: "inline ml-3" %></span>
  <% end %>
  <span class="text-xs text-slate-600 mt-4">Powered by WorkOS and Okta</span>
</div>