<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Workos Rails Demo" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Workos Rails Demo">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="container">
    <header class="fixed top-0 left-0 w-full h-16 bg-white shadow flex items-center justify-between px-5">
      <a href="/" class="font-bold text-lg">@alidacodes</a>
      <% if authenticated? %>
        <nav>
          <span class="font-medium text-slate-600">Welcome, <%= session[:user_first_name] %> <%= session[:user_last_name] %> </span>
          <%= link_to "Directory", directory_path, class: "m-4" %>
          <%= link_to "Logout", logout_path, method: :delete %>
        </nav>
      <% else %>
        <%= link_to "Login", login_path %>
      <% end %>
    </header>
    <main class="mx-auto mt-28 px-5 flex">
      <%= yield %>
    </main>
  </body>
</html>
